APP_NAME="f1-api"
ENV="dev"

# 默认使用 SQLite（本地文件数据库）
DB_SCHEME="sqlite"
SQLITE_PATH="./.data/app.db"

# 若你未来切换到 MySQL，再启用下面这些：
# DB_SCHEME="mysql"
# DB_HOST="localhost"
# DB_PORT=3306
# DB_USER="f1"
# DB_PASSWORD="f1"
# DB_NAME="f1"

JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# 用于启动时创建默认管理员账号
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_PASSWORD="admin123"

